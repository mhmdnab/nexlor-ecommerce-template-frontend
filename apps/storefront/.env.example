# Public base URL of the NestJS API (browser + server fetches). Include /api.
# Local:      http://localhost:4000/api
# Production: https://<your-api>.onrender.com/api
NEXT_PUBLIC_API_URL=http://localhost:4000/api

# Public site URL (used for canonical/OG/sitemap). No trailing slash.
# Local:      http://localhost:3000
# Production: https://<your-storefront>.vercel.app
NEXT_PUBLIC_SITE_URL=http://localhost:3000
